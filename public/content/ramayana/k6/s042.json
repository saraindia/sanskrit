.","words":[{"d":"कुमुदः","m":"Kumuda"},{"d":"तु","m":"also"},{"d":"कोटीभि","m":"one crore"},{"d":"र्दशभि","m":"ten"},{"d":"आर्वृतः","m":"surrounded by"},{"d":"पूर्वद्वारं","m":"east gate"},{"d":"आवृत्य","m":"surrounded"},{"d":"बलवां","m":"mighty"},{"d":"स्तस्थौ","m":"remained"},{"d":"हरिभि","m":"monkeys also"},{"d":"र्जितकाशिभिः","m":"appearing victorious."}]},{"v":24,"dev":"साहाय्यार्थंतुतस्यैवनिविष्टःप्रघसोहरिः ।पनसश्चमहाबाहुर्वानरैर्बहुभिर्वृतः","trans":"Praghasa the broad shouldered Vanara, was surrounded by Panasa for assisting him who encamped surrounded by many.","words":[{"d":"प्रघसो","m":"Praghasa"},{"d":"हरिः","m":"monkey"},{"d":"महाबाहु","m":"broad shouldered"},{"d":"पनसश्च","m":"Panasa also"},{"d":"वानर","m":"Vanaras"},{"d":"साहाय्यार्थं","m":"for assisting"},{"d":"तस्यैव","m":"himself"},{"d":"निविष्टः","m":"encamped"},{"d":"बहुभि","m":"many"},{"d":"आर्वृतः","m":"surrounded."}]},{"v":25,"dev":"दक्षिणंद्वारमागम्यवीरःशतबलिःकपिः ।आवृत्यबलवांस्तस्थौविंशत्याकोटिभिर्वृतः","trans":"Valiant Satabali with twenty crores of monkeys stood besieging the south gate.","words":[{"d":"वीरः","m":"valiant"},{"d":"शतबलिः","m":"Satabali"},{"d":"कपिः","m":"monkey"},{"d":"विंशत्या","m":"twenty"},{"d":"कोटिभि","m":"crores"},{"d":"आवृत्य","m":"surrounded by"},{"d":"बलवांस्तस्थौ","m":"stood besieging"},{"d":"दक्षिणं","m":"south"},{"d":"द्वारमागम्य","m":"reached the gate."}]},{"v":26,"dev":"सुषेणःपश्चिमद्वारंगतस्तारापिताहरिः ।आवृत्यबलवांस्तस्थौषष्टिकोटिभिरावृतः","trans":"Sushena, father of Tara, (Vali's wife) the mighty, stood with sixty crores of monkeys at the western gate.","words":[{"d":"गतस्तारापिता","m":"father of Tara (wife of Vali)"},{"d":"बलवांस्तस्थौ","m":"the mighty"},{"d":"सुषेणः","m":"Sushena"},{"d":"आवृत्य","m":"along with"},{"d":"षष्टिकोटिभिरावृतः","m":"sixty crores of monkeys surrounding"},{"d":"पश्चिमद्वारं","m":"at the western gate."}]},{"v":27,"dev":"उत्तरंद्वारमासाद्यरामःसौमित्रिणासह ।आवृत्यबलवांस्तस्थौसुग्रीवश्चहरीश्वरः","trans":"Reaching the north gate, Sri 