"},{"d":"शयानौ","m":"lying"},{"d":"तौ","m":"both"},{"d":"सम्परिवार्य","m":"surrounding"},{"d":"तस्थुः","m":"stood"},{"d":"आर्ताः","m":"despondent"},{"d":"परमम्","m":"extremely"},{"d":"विषादम्","m":"sorrow"},{"d":"जग्मुःच","m":"remained."}]}]}