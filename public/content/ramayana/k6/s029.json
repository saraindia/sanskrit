[{"d":"शासत","m":"by order"},{"d":"यस्यमे","m":"by that alone"},{"d":"जिह्वा","m":"by tongue"},{"d":"शुभाशुभम्","m":"auspicious and inauspicious"},{"d":"प्रयच्छति","m":"articulating"},{"d":"माम्","m":"to me"},{"d":"परुषम्","m":"harsh"},{"d":"वच","m":"words"},{"d":"वक्तुम्","m":"to speak"},{"d":"मृत्यो","m":"death"},{"d":"भयम्","m":"fear"},{"d":"नास्तिकिंनु","m":"do you not have."}]},{"v":12,"dev":"अप्येवदहनंस्पृष्टवावनेतिष्ठन्तिपादपाः ।राजदोषपरामृष्टास्तिष्ठन्तेनापराधिनः","trans":"\"Trees may remain unscathed even on touching forest fire, but those who are punishable do not remain unpunished on account of the king and are treated harshly.\"","words":[{"d":"पादपा","m":"trees"},{"d":"दहनम्","m":"fire"},{"d":"स्पृष्टवा","m":"touching"},{"d":"आप्येव","m":"even after"},{"d":"वने","m":"in forest"},{"d":"तिष्ठन्ति","m":"remains unscathed"},{"d":"राजदोषपरामृष्टा","m":"treated harshly on account of punishment of the king"},{"d":"अपराधिन","m":"those who are punishable"},{"d":"नतिष्ठन्ते","m":"not remain unpunished."}]},{"v":13,"dev":"हन्यामहंत्विमौपापौशत्रुपक्षप्रशंसकौ ।यदिपूर्वोपकारैस्तुनक्रोधोमृदुतांव्रजेत्","trans":"\"I would have slayed these two sinners who praise the enemy side, if my anger had not softened and remembered their earlier services.\"","words":[{"d":"अहम्","m":"I"},{"d":"हन्याम्","m":"would have slayed"},{"d":"त्वम्इमौपापौ","m":"these two sinners"},{"d":"शत्रुपक्षप्रशंसकौ","m":"who praise the enemy side"},{"d":"यदि","m":"if"},{"d":"मे","m":"my"},{"d":"क्रोध","m":"anger"},{"d":"न","m":"not"},{"d":"मृदुताम् व्रजेत्","m":"softened"},{"d":"पूर्वोपकारै","m":"due to earlier service."}]},{"v":14,"dev":"अपध्वंसतगच्छध्वंसन्निकर्षाद्इतोमम ।नहिवांहन्तुमिच्छामिस्मराम्युपकृतानिवाम् हतावेवकृतघ्नौतौमयिस्नेहपराङ्मुखौ ।","trans":"\"You get away from here, disappear from here. On the contrary since I remember your earlier actions performed by you, I do not wish to kill you. Indeed, both of you are devoid of love and are ungrateful. You stand killed (already).\"","words":[{"d