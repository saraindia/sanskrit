्य:","m":"gazing"},{"d":"सर्वान्","m":"all"},{"d":"महता:","m":"loud"},{"d":"स्वरेण:","m":"tone"},{"d":"उवाच:","m":"addressed."}]},{"v":12,"dev":"रावणोनामदुर्वृत्तोराक्षसोराक्षसेश्वरः ।तस्याहमनुजोभ्राताविभीषणइतिश्रुतः","trans":"\"I am called Vibheeshana, the younger brother of Ravana, the king of Rakshasas and of evil conduct.\"","words":[{"d":"रावणोनाम:","m":"Ravana by name"},{"d":"दुर्वृत्तः","m":"of evil conduct"},{"d":"राक्षसेश्वरः","m":"king of Rakshasas"},{"d":"राक्षसः","m":"Rakshasa"},{"d":"अहम्","m":"I"},{"d":"तस्य:","m":"his"},{"d":"अनुजःभ्राता:","m":"younger brother"},{"d":"विभीषणइति:","m":"as Vibheeshana"},{"d":"श्रुतः","m":"called."}]},{"v":13,"dev":"तेनसीताजनस्थानाद्धृताहत्वाजटायुषम् ।रुद्दाचविवशादीनाराक्षसीभिस्सुरक्षिता","trans":"\"Having been carried away from Janasthana by him (Ravana) poor and pitiable Sita is detained and protected by the Rakshasas.\"","words":[{"d":"तेन:","m":"by him"},{"d":"जटायुषम्","m":"Jatayu"},{"d":"हत्वा:","m":"killing"},{"d":"सीता:","m":"Sita"},{"d":"जनस्थानात्","m":"from Janasthana"},{"d":"हृता:","m":"having been carried away"},{"d":"रुद्दा:","m":"detained"},{"d":"विवशा:","m":"poor"},{"d":"दीना:","m":"pitiable"},{"d":"राक्षसीभिः","m":"by Rakshasas"},{"d":"सुरक्षिता:","m":"protected."}]},{"v":14,"dev":"तमहंहेतुभिर्वाक्यैर्विविधैश्चन्यदर्शयम् ।साधुनिर्यात्यतांसीतारामायेतिपुनःपुनः","trans":"\"I argued with him again and again in several ways to explain him and admonished him saying 'restore Sita to Rama'.\"","words":[{"d":"सीता:","m":"Sita"},{"d":"साधु:","m":"correct"},{"d":"रामाय:","m":"to Rama"},{"d":"निर्यात्यताम् इति:","m":"to restore"},{"d":"पुनःपुनः","m":"again and again"},{"d":"तम्","m":"him"},{"d":"अहम्","m":"I"},{"d":"हेतुभिः","m":"argued also"},{"d":"विविधैः","m":"in several ways"},{"d":"वाक्यैः","m":"words"},{"d":"न्यदर्शयम्","m":"to explain."}]},{"v":15,"dev":"सचनप्रतिजग्राहरावणःकालचोदितः ।उच्यमानंहितंवाक्यंविपरीतइवौषधम्","trans":"\"Impelled by death Ravana would not take good words of advice tendered to him just as one who is impelled by death does not take medicine.\"","words":[{"d":"सःरावणः","m":"that Ravana"},{"d":"कालचोदितः","m":"impelled by death"},{"d":"उच्यमानम्","m":"advice tendered"},{"d":"हितम्","m":"good"},{"d":"वाक्यम्","m":"words"},{"d":"विपरीतः","m":"contrary to"},{"d":"औषधम् इव:","m":"like the medicine"},{"d":"नप्रतिजग्राह:","m":"would not take."}]},{"v":16,"dev":"सोऽहंपरुषितस्तेनदासवच्चावमानितः ।त्यक्त्वापुत्रांश्चदारांश्चराघवंशरणंगतः","trans":"\"Leaving my sons and wife, I have come for protection of Raghava having been put to shame by him (Ravana), spoken to harshly and treated like a slave.\"","words":[{"d":"तेन:","m":"by him"},{"d":"परुषितः","m":"spoken to harshly"},{"d":"दासवत्","m":"treated like a slave"},{"d":"अवमानितः","m":"having been put to shame"},{"d":"सःअहम्","m":"that I"},{"d":"पुत्रांश्चदारांश्च:","m":"sons and wife"},{"d":"त्वक्त्वा:","m":"giving up"},{"d":"राघवम्","m":"of Raghava"},{"d":"शरणंगतः","m":"came for protection."}]},{"v":17,"dev":"सर्वलोकशरण्यायराघवायमहात्मने ।निवेदयतमांक्षिप्रंविभीषणमुपस्थितम्","trans":"At once you may inform Raghava who is a protector of the whole world that I, Vibheeshana, are waiting here.","words":[{"d":"महात्मने:","m":"O great soul"},{"d":"सर्वलोकशरण्याय:","m":"one who is a protector of the whole world"},{"d":"राघवाय:","m":"Raghava's"},{"d":"विभीषणं:","m":"Vibheeshana"},{"d":"माम्","m":"I"},{"d":"उपस्थितम्","m":"waiting here"},{"d":"क्षिप्रम्","m":"at once"},{"d":"निवेदयत:","m":"you may inform."}]},{"v":18,"dev":"एतत्तुवचनंश्रुत्वासुग्रीवोलघुविक्रमः ।लक्ष्मणस्याग्रतोरामंसम्रब्धमिदमब्रवीत्","trans":"Highly valiant Sugriva having heard all this (from Vibheeshana) eagerly spoke these words to Rama in the presence of Lakshmana.","words":[{"d":"लघुविक्रमः","m":"highly valiant"},{"d":"सुग्रीवः","m":"Sugriva"},{"d":"एतत्","m":"all this"},{"d":"वचनम्","m":"words"},{"d":"श्रुत्वा:","m":"having heard"},{"d":"लक्ष्मणस्य:","m":"Lakshmana's"},{"d":"अग्रतः","m":"presence"},{"d":"रामम्","m":"Rama's"},{"d":"सम्रब्धतरम्","m":"